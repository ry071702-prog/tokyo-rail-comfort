# このファイルを .env.local にコピーして値を埋める (.env.local はコミットしない)
# ⚠️ すべて未設定でもアプリは起動する:
#    - 運行情報 API はモックにフォールバック (画面に「デモデータ」バッジ)
#    - 混雑推定は国交省CSVのミラー (lib/data/baseline.ts) で動く
#    デプロイ手順は docs/DEPLOY.md

# ODPT（公共交通オープンデータセンター）アクセストークン
# 取得: https://developer.odpt.org/ で無料登録し consumerKey を発行
# ※ サーバ側でのみ使用。クライアントに露出させないこと（NEXT_PUBLIC_ を付けない）
#    付けるとビルド時にクライアントJSへ埋め込まれ、ブラウザから誰でも読めてしまう
ODPT_CONSUMER_KEY=your_odpt_consumer_key_here

# Supabase
# 静的マスタ（路線・駅・区間・混雑率・時間帯係数）の保存先。未設定でも UI は動く
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# サーバ側スクリプト（データ投入）用。RLS を素通りする強い鍵なのでクライアントに出さない
# 使用箇所: npm run seed:master / seed:congestion / seed:timeband / collect:train-info
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- 以下は .env ではなく GitHub Actions 側で設定する ------------------------
# COLLECT_ENABLED
#   運行情報の定期収集ワークフロー（.github/workflows/collect-train-info.yml）の
#   実行ガード。GitHub の Settings > Secrets and variables > Actions > Variables に
#   COLLECT_ENABLED=true を登録するまでジョブはスキップされる（誤作動防止）
#   同画面の Secrets 側に ODPT_CONSUMER_KEY / NEXT_PUBLIC_SUPABASE_URL /
#   SUPABASE_SERVICE_ROLE_KEY を登録しておくこと
